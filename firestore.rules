rules_version = '2';

// Deploy with:  firebase deploy --only firestore:rules
//
// These rules lock down the Firestore database so that only authenticated
// users can read or write, and all writes are validated for size/shape.
// Adjust to your needs — the defaults below are a reasonable starting point.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Questions collection ──────────────────────────────────
    match /questions/{questionId} {
      // Anyone authenticated can read questions.
      allow read: if request.auth != null;

      // Authenticated users can create questions that pass validation.
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['question', 'answers', 'correct', 'createdAt'])
        && request.resource.data.question is string
        && request.resource.data.question.size() > 0
        && request.resource.data.question.size() <= 1000
        && request.resource.data.answers is map
        && request.resource.data.correct in ['A', 'B', 'C', 'D']
        && request.resource.data.createdAt is number;

      // Only the document creator or an admin can update/delete.
      // If you don't store an 'owner' field yet, loosen this to
      //   allow delete: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Leaderboard collection ────────────────────────────────
    match /leaderboard/{userId} {
      allow read: if request.auth != null;

      // Users may only write their own leaderboard entry.
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.count is number
        && request.resource.data.count >= 0;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
